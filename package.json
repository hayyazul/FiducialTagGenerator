{
  "name": "apriltag-generator",
  "private": true,
  "version": "0.0.0",
  "description": "Free, open, browser-based AprilTag and ArUco marker generator. Print PDF tags for robotics, computer vision, and FRC. Supports recursive nested tags.",
  "keywords": [
    "apriltag",
    "apriltag-generator",
    "apriltag-pdf",
    "aruco",
    "aruco-generator",
    "fiducial-marker",
    "fiducial",
    "robotics",
    "computer-vision",
    "frc",
    "limelight"
  ],
  "homepage": "https://hayyazul.github.io/apriltag-generator/",
  "author": "Ayyaz Hassan",
  "repository": {
    "type": "git",
    "url": "https://github.com/hayyazul/apriltag-generator.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.11.30",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
